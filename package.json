{
  "name": "learning-companion",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "check:morning": "bash scripts/morning-check.sh",
    "check:morning:offline": "bash scripts/morning-check.sh",
    "check:morning:browser": "bash scripts/morning-check-browser.sh",
    "check:morning:native": "bash scripts/morning-check-native.sh",
    "morning:adversarial": "node scripts/adversarial-gate-check.mjs",
    "demo:capture-resume": "node scripts/demo-capture-resume.mjs",
    "demo:morning": "node scripts/build-morning-demo.mjs",
    "demo:patch-intake-negative": "node scripts/patch-intake-negative-receipt.mjs --out dist/patch-intake-negative/PATCH_INTAKE_NEGATIVE_RECEIPT.json",
    "morning:determinism": "node scripts/morning-determinism-check.mjs",
    "morning:perf": "node scripts/perf-budget-check.mjs --out dist/perf-budget/PERF_BUDGET.json",
    "morning:perf:selftest": "node scripts/perf-budget-self-test.mjs",
    "morning:receipts": "node scripts/validate-morning-receipts.mjs",
    "demo:morning:serve": "node scripts/serve-morning-demo.mjs",
    "demo:morning:serve:smoke": "node scripts/serve-morning-demo.mjs --smoke",
    "demo:return-import-dry-run": "node scripts/return-file-import-dry-run.mjs",
    "demo:return-import-dry-run:smoke": "node scripts/return-file-import-dry-run.mjs --workspace dist/morning-demo/sample-workspace.json --return-file dist/morning-demo/patches/sample-mobile-inbox-patch.json --return-file dist/morning-demo/patches/sample-review-progress-patch.json --out .codex-tmp/return-import-dry-run/receipt.json",
    "dogfood:validate": "node scripts/validate-dogfood-runbook.mjs",
    "dogfood:validate:smoke": "node scripts/validate-dogfood-runbook.mjs --runbook dist/morning-demo/DOGFOOD_RUNBOOK.md --out .codex-tmp/dogfood-runbook/receipt.json",
    "mac:manual:validate": "node scripts/validate-mac-manual-qa.mjs",
    "mac:manual:validate:smoke": "node scripts/validate-mac-manual-qa.mjs --qa dist/morning-demo/MAC_MANUAL_QA.md --out .codex-tmp/mac-manual-qa/receipt.json",
    "agent:study-loop": "node scripts/agent-study-loop-check.mjs --out .codex-tmp/agent-study-loop-smoke/receipt.json",
    "smoke:agent-study-loop": "node scripts/agent-study-loop-check.mjs --out .codex-tmp/agent-study-loop-smoke/receipt.json",
    "mac:build": "bash scripts/mac-build.sh",
    "mirror:integrity": "node scripts/mirror-integrity-check.mjs",
    "check:static-return": "node scripts/static-return-loop-check.mjs",
    "smoke": "node scripts/smoke-web.mjs",
    "smoke:text-fragment": "node scripts/smoke-text-fragment-browser.mjs",
    "smoke:source-resume": "node scripts/smoke-source-resume.mjs",
    "smoke:post-save-hints": "node scripts/post-save-hint-visual-check.mjs",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "smoke:harmony": "node scripts/smoke-harmony-schema.mjs && node scripts/smoke-harmony-scaffold.mjs"
  }
}
