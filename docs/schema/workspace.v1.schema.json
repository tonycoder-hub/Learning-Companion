{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tonycoder-hub.github.io/Learning-Companion/schema/workspace.v1.schema.json",
  "title": "Learning Companion Workspace v1",
  "type": "object",
  "required": ["schema", "schemaVersion", "version", "clientId", "activeSessionId", "sessions", "createdAt", "updatedAt"],
  "properties": {
    "schema": {
      "const": "learning-companion.workspace.v1"
    },
    "version": {
      "const": 1
    },
    "schemaVersion": {
      "const": 1
    },
    "clientId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "activeSessionId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "importedPatches": {
      "type": "array",
      "items": { "type": "string", "maxLength": 128 },
      "uniqueItems": true
    },
    "importedReviewPatches": {
      "type": "array",
      "items": { "type": "string", "maxLength": 128 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "session": {
      "type": "object",
      "required": [
        "id",
        "originClientId",
        "title",
        "sourceTitle",
        "sourceUrl",
        "materialType",
        "tags",
        "focusMode",
        "notesMarkdown",
        "captures",
        "reviewCards",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "originClientId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "title": { "type": "string", "maxLength": 160 },
        "sourceTitle": { "type": "string", "maxLength": 160 },
        "sourceUrl": { "type": "string", "maxLength": 2048 },
        "materialType": {
          "enum": ["article", "video", "doc", "course", "book", "other"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 64 },
          "uniqueItems": true
        },
        "focusMode": {
          "enum": ["capture", "synthesize", "review"]
        },
        "notesMarkdown": { "type": "string", "maxLength": 120000 },
        "captures": {
          "type": "array",
          "items": { "$ref": "#/$defs/capture" }
        },
        "reviewCards": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewCard" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "capture": {
      "type": "object",
      "required": [
        "id",
        "originClientId",
        "quote",
        "thought",
        "timestamp",
        "tags",
        "createdAt",
        "capturedAt",
        "updatedAt",
        "promotedToReview"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "originClientId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "quote": { "type": "string", "maxLength": 12000 },
        "thought": { "type": "string", "maxLength": 12000 },
        "timestamp": { "type": "string", "maxLength": 32 },
        "sourceTitle": { "type": "string", "maxLength": 160 },
        "sourceUrl": { "type": "string", "maxLength": 2048 },
        "materialType": {
          "enum": ["article", "video", "doc", "course", "book", "other"]
        },
        "sourceProvenance": {
          "enum": ["snapshot", "inbound", "inbox", "inherited", "unknown"]
        },
        "inboxPatchId": { "type": "string", "maxLength": 128 },
        "inboxCaptureId": { "type": "string", "maxLength": 128 },
        "questionResolvedAt": {
          "description": "Optional timestamp marking a captured question as resolved. Missing or null means a question-shaped capture is still open.",
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "questionParkedAt": {
          "description": "Optional timestamp marking a captured question as temporarily parked. Missing or null means the question is not parked. A timestamp means the question remains unresolved but is excluded from the active open-question focus queue. It is cleared when the question is resumed or resolved; if questionResolvedAt is set, import normalization treats questionParkedAt as null.",
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 64 },
          "uniqueItems": true
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "capturedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "promotedToReview": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "reviewCard": {
      "type": "object",
      "required": [
        "id",
        "originClientId",
        "prompt",
        "answer",
        "sourceCaptureId",
        "dueAt",
        "strength",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "originClientId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "prompt": { "type": "string", "maxLength": 12000 },
        "answer": { "type": "string", "maxLength": 12000 },
        "sourceCaptureId": { "type": "string" },
        "dueAt": { "type": "string", "format": "date-time" },
        "lastReviewedAt": { "type": "string", "format": "date-time" },
        "strength": { "type": "integer", "minimum": 0, "maximum": 5 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
